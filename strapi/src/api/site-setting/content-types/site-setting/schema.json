{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site configuration (hours, contact info, social links)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "restaurantName": { "type": "string", "required": true, "default": "Bistrot De La Cour" },
    "tagline": { "type": "string" },
    "address": { "type": "string", "required": true },
    "city": { "type": "string", "required": true },
    "zipCode": { "type": "string" },
    "country": { "type": "string", "default": "Belgique" },
    "phone": { "type": "string", "required": true },
    "email": { "type": "email" },
    "openingHours": { "type": "json" },
    "heroTitle": { "type": "string" },
    "heroSubtitle": { "type": "text" },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "facebookUrl": { "type": "string" },
    "instagramUrl": { "type": "string" },
    "googleMapsUrl": { "type": "string" },
    "googleBusinessUrl": { "type": "string" },
    "tripadvisorUrl": { "type": "string" },
    "cancellationPolicy": { "type": "richtext" },
    "groupBookingNote": { "type": "richtext" },
    "serviceNote": { "type": "richtext" },
    "heroBadgeRating": { "type": "string", "default": "4.7" },
    "heroBadgeReviewCount": { "type": "integer", "default": 178 }
  }
}
