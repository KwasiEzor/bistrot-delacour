# Production environment variables for Strapi

# Server
HOST=0.0.0.0
PORT=1337

# Secrets (GENERATE SECURE VALUES FOR PRODUCTION)
APP_KEYS=change-me-to-a-random-string-1,change-me-to-a-random-string-2
ADMIN_JWT_SECRET=change-me-to-a-secure-random-string
API_TOKEN_SALT=change-me-to-a-secure-random-string
TRANSFER_TOKEN_SALT=change-me-to-a-secure-random-string
ENCRYPTION_SECRET=change-me-to-a-secure-random-string
JWT_SECRET=change-me-to-a-secure-random-string

# Database (PostgreSQL for production)
DATABASE_CLIENT=postgres
DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_NAME=bistrot-delacour
DATABASE_USERNAME=your-db-user
DATABASE_PASSWORD=your-db-password
DATABASE_SSL=true

# URL
STRAPI_URL=https://cms.bistrot-delacour.be
FRONTEND_URL=https://bistrot-delacour.be

# AWS S3 (for media uploads in production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_ACCESS_SECRET=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=bistrot-delacour-media
