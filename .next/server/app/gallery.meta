{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/gallery/layout,_N_T_/(app)/gallery/page,_N_T_/gallery"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/gallery/__PAGE__",
    "/!KGFwcCk/gallery",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}