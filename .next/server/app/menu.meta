{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/menu/layout,_N_T_/(app)/menu/page,_N_T_/menu"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/menu/__PAGE__",
    "/!KGFwcCk/menu",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}