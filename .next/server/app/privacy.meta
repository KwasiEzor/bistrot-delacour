{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/privacy/layout,_N_T_/(app)/privacy/page,_N_T_/privacy"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/privacy/__PAGE__",
    "/!KGFwcCk/privacy",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}